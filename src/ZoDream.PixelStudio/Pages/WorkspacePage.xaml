<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ZoDream.PixelStudio.Pages.WorkspacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:bhv="using:ZoDream.PixelStudio.Behaviors"
    xmlns:ctl="using:ZoDream.PixelStudio.Controls"
    xmlns:cvt="using:ZoDream.PixelStudio.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dlg="using:ZoDream.PixelStudio.Dialogs"
    xmlns:ivy="using:Microsoft.Xaml.Interactivity"
    xmlns:local="using:ZoDream.PixelStudio.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:ZoDream.PixelStudio.ViewModels"
    mc:Ignorable="d">
    <Page.DataContext>
        <vm:WorkspaceViewModel />
    </Page.DataContext>
    <Page.Resources>
        <cvt:IsGroupConverter x:Key="IsGroup" />
        <DataTemplate x:Key="LayerTemplate" x:DataType="vm:LayerViewModel">
            <TreeViewItem
                AutomationProperties.Name="{Binding Name}"
                IsExpanded="True"
                IsSelected="{Binding IsSelected, Mode=TwoWay}"
                ItemsSource="{Binding Children}">
                <TreeViewItem.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem
                            Command="{Binding Workspace.CutCommand}"
                            CommandParameter="{Binding}"
                            Text="剪切" />
                        <MenuFlyoutItem
                            Command="{Binding Workspace.CopyCommand}"
                            CommandParameter="{Binding}"
                            Text="复制" />
                        <MenuFlyoutItem
                            Command="{Binding Workspace.PasteCommand}"
                            CommandParameter="{Binding}"
                            Text="粘贴" />
                        <MenuFlyoutSeparator />

                        <MenuFlyoutItem
                            Command="{Binding Workspace.LayerHiddenCommand}"
                            CommandParameter="{Binding}"
                            Text="隐藏" />
                        <MenuFlyoutItem
                            Command="{Binding Workspace.OtherHiddenCommand}"
                            CommandParameter="{Binding}"
                            Text="隐藏其他" />
                        <MenuFlyoutItem
                            Command="{Binding Workspace.OtherVisibleCommand}"
                            CommandParameter="{Binding}"
                            Text="显示其他" />
                        <MenuFlyoutItem
                            Command="{Binding Workspace.LayerLockCommand}"
                            CommandParameter="{Binding}"
                            Text="锁定" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem
                            Command="{Binding Workspace.LayerRenameCommand}"
                            CommandParameter="{Binding}"
                            Text="重命名" />
                        <MenuFlyoutItem
                            Command="{Binding Workspace.LayerPropertyCommand}"
                            CommandParameter="{Binding}"
                            Text="图层属性" />
                        <MenuFlyoutItem
                            Command="{Binding Workspace.DeleteLayerCommand}"
                            CommandParameter="{Binding}"
                            Text="删除" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem
                            Command="{Binding Workspace.LayerApplyCommand}"
                            CommandParameter="{Binding}"
                            Text="应用"
                            ToolTipService.ToolTip="应用属性中的缩放旋转" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem
                            Command="{Binding Workspace.AddGroupCommand}"
                            CommandParameter="{Binding}"
                            Text="分组" />
                        <MenuFlyoutItem
                            Command="{Binding Workspace.UngroupCommand}"
                            CommandParameter="{Binding}"
                            IsEnabled="{Binding Children, Converter={StaticResource IsGroup}}"
                            Text="取消分组" />

                    </MenuFlyout>
                </TreeViewItem.ContextFlyout>
                <Grid Height="60">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>
                    <Image Source="{Binding PreviewImage}" Stretch="UniformToFill" />
                    <TextBlock
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Text="{Binding Name}" />
                    <ctl:ToggleIcon
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Command="{Binding Workspace.LayerVisibleToggleCommand}"
                        CommandParameter="{Binding}"
                        IsOn="{Binding IsVisible, Mode=TwoWay}"
                        OffIcon="&#xED1A;"
                        OnIcon="&#xE7B3;" />
                    <ctl:ToggleIcon
                        Grid.Column="3"
                        VerticalAlignment="Center"
                        Command="{Binding Workspace.LayerLockToggleCommand}"
                        CommandParameter="{Binding}"
                        IsOn="{Binding IsLocked, Mode=TwoWay}"
                        OffIcon="&#xE785;"
                        OnIcon="&#xE72E;" />
                </Grid>
            </TreeViewItem>
        </DataTemplate>
        <ctl:LayerItemTemplateSelector x:Key="LayerItemTemplateSelector" LayerTemplate="{StaticResource LayerTemplate}" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <ProgressBar
            VerticalAlignment="Top"
            Background="Transparent"
            IsIndeterminate="{Binding IsLoading}" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Button
                    Command="{Binding UndoCommand}"
                    Content="&#xE7A7;"
                    IsEnabled="{Binding UndoEnabled}"
                    Style="{StaticResource LargeIconBtn}"
                    ToolTipService.ToolTip="撤销" />
                <Button
                    Command="{Binding RedoCommand}"
                    Content="&#xE7A6;"
                    IsEnabled="{Binding RedoEnabled}"
                    Style="{StaticResource LargeIconBtn}"
                    ToolTipService.ToolTip="重做" />
                <AppBarSeparator />
                <DropDownButton
                    Background="Transparent"
                    BorderThickness="0"
                    ToolTipService.ToolTip="模式切换">
                    <DropDownButton.Content>
                        <FontIcon Glyph="{Binding SelectedModeIcon}" />
                    </DropDownButton.Content>
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem
                                Command="{Binding ModeCommand}"
                                CommandParameter="View"
                                Text="浏览模式">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xF271;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem
                                Command="{Binding ModeCommand}"
                                CommandParameter="Move"
                                Text="移动模式">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8B0;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem
                                Command="{Binding ModeCommand}"
                                CommandParameter="Pen"
                                Text="钢笔工具">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xEDFB;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem
                                Command="{Binding ModeCommand}"
                                CommandParameter="PenJoint"
                                Text="节点编辑">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xF003;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
                <ToggleButton
                    Background="Transparent"
                    BorderThickness="0"
                    ToolTipService.ToolTip="吸附">
                    <ToggleButton.Content>
                        <FontIcon Glyph="&#xE8DC;" />
                    </ToggleButton.Content>
                </ToggleButton>
                <AppBarSeparator />
                <Button
                    Command="{Binding SaveCommand}"
                    Content="&#xE74E;"
                    Style="{StaticResource LargeIconBtn}"
                    ToolTipService.ToolTip="保存" />
                <Button
                    Command="{Binding AddLayerCommand}"
                    Content="&#xE710;"
                    Style="{StaticResource LargeIconBtn}"
                    ToolTipService.ToolTip="添加图层" />
                <Button
                    Command="{Binding DeleteLayerCommand}"
                    Content="&#xE74D;"
                    IsEnabled="{Binding IsSelectedLayer}"
                    Style="{StaticResource LargeIconBtn}"
                    ToolTipService.ToolTip="删除图层" />
                <Button
                    Command="{Binding ImportFolderCommand}"
                    Content="&#xE8DA;"
                    Style="{StaticResource LargeIconBtn}"
                    ToolTipService.ToolTip="导入文件夹" />
                <AppBarSeparator />
                <Button
                    Command="{Binding LayerPropertyCommand}"
                    Content="&#xE713;"
                    IsEnabled="{Binding IsSelectedLayer}"
                    Style="{StaticResource LargeIconBtn}"
                    ToolTipService.ToolTip="图层属性" />
                <AppBarButton
                    Command="{Binding ExportCommand}"
                    Content="&#xEDE1;"
                    Style="{StaticResource LargeIconBtn}"
                    ToolTipService.ToolTip="导出" />
            </StackPanel>

            <ToggleSwitch
                Grid.Column="2"
                IsOn="{Binding LayerMode, Mode=TwoWay}"
                OffContent="图层"
                OnContent="效果图" />
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>
            <ctl:ImageCanvasShell
                x:Name="CanvasShell"
                AllowDrop="True"
                SelectedCommand="{Binding EditorSelectedCommand}">
                <ivy:Interaction.Behaviors>
                    <bhv:DragFileBehavior Command="{Binding DragFileCommand}" />
                </ivy:Interaction.Behaviors>
            </ctl:ImageCanvasShell>

            <Pivot Grid.Column="1">
                <PivotItem Header="图层">
                    <TreeView ItemTemplateSelector="{StaticResource LayerItemTemplateSelector}" ItemsSource="{Binding LayerItems}">
                        <ivy:Interaction.Behaviors>
                            <bhv:SelectionChangedBehavior Command="{Binding SelectionChangedCommand}" />
                        </ivy:Interaction.Behaviors>
                    </TreeView>
                </PivotItem>
                <PivotItem Header="Slot">
                    <ListBox ItemsSource="{Binding SlotItems}" Style="{StaticResource CustomListBox}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:SlotItemViewModel">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto" />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind Name}" />
                                    <Slider
                                        Grid.Column="1"
                                        Maximum="{x:Bind FrameCount}"
                                        Visibility="{x:Bind cvt:ConverterHelper.VisibleIf(FrameCount)}"
                                        Value="{x:Bind FrameIndex, Mode=TwoWay}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </PivotItem>
                <PivotItem Header="动画">
                    <ListBox ItemsSource="{Binding AnimationItems}" Style="{StaticResource CustomListBox}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:AnimationItemViewModel">
                                <Grid>
                                    <TextBlock Text="{x:Bind Name}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </PivotItem>
                <PivotItem Header="Skin">
                    <ListBox ItemsSource="{Binding SkinItems}" Style="{StaticResource CustomListBox}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:SkinItemViewModel">
                                <Grid>
                                    <TextBlock Text="{x:Bind Name}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </PivotItem>
                <PivotItem Header="资源">
                    <ListBox ItemsSource="{Binding ResourceItems}" Style="{StaticResource CustomListBox}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ResourceItemViewModel">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{x:Bind Name}" />
                                    <TextBlock
                                        Grid.Row="1"
                                        FontSize="12"
                                        Foreground="Gray"
                                        Text="{x:Bind FullPath}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </PivotItem>
            </Pivot>

        </Grid>
    </Grid>
</Page>
